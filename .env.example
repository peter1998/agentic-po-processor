# Anthropic (Claude Sonnet — text extraction + Vision for scanned files)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Voyage AI (embeddings for RAG)
VOYAGE_API_KEY=your_voyage_api_key_here

# LangSmith (observability / tracing)
ANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=<your LangSmith key here>
LANGCHAIN_PROJECT=flatrock-po-agent
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=<your LangSmith key here>
LANGSMITH_PROJECT=flatrock-po-agent

# Internal API auth (protects /review/approve)
API_KEY=change_me_to_a_random_secret

# Storage
DATABASE_PATH=./data/purchase_orders.db
CHROMA_PERSIST_PATH=./data/chroma_db

# Gate thresholds (kept configurable, not hardcoded in logic)
GATE1_COMPLETENESS_THRESHOLD=0.6
GATE1_MAX_RETRIES=1
GATE2_VALIDATION_RATE_THRESHOLD=0.75